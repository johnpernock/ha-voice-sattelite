# =============================================================================
#  voice.conf — local configuration for voice-setup.sh
# =============================================================================
#
#  Copy this file to voice.conf and set your values:
#    cp voice.conf.example voice.conf
#    nano voice.conf
#    sudo bash voice-setup.sh
#
#  voice.conf is git-ignored — git pull will never overwrite your settings.
#  Only set the variables you want to override.
# =============================================================================

# Name shown in Home Assistant's device list
# VOICE_SATELLITE_NAME="front-door-satellite"

# ── Hardware ──────────────────────────────────────────────────────────────────
# auto          — script detects what's connected (recommended to start)
# 2mic_hat      — ReSpeaker 2-Mic Pi HAT V1/V2 (GPIO, requires driver install)
# voice_bonnet  — Adafruit Voice Bonnet #4757 (WM8960, requires driver install)
# respeaker_lite — ReSpeaker Lite (USB, plug and play)
# usb           — any generic USB microphone/speaker
# custom        — set VOICE_MIC_DEVICE and VOICE_SPEAKER_DEVICE manually
#
# VOICE_HARDWARE="auto"

# ── 2-Mic HAT version ────────────────────────────────────────────────────────
# v1_0 = ReSpeaker 2-Mic Pi HAT V1.0 (older, most common)
# v2_0 = ReSpeaker 2-Mic Pi HAT V2.0 (newer)
# Default is v1_0
#
# VOICE_2MIC_VERSION="v1_0"

# ── Audio devices (only set these if VOICE_HARDWARE=custom) ───────────────────
# Find your device names by running: sudo bash voice-setup.sh --detect
# Use plughw: format for best compatibility, e.g. plughw:CARD=seeed2micvoicec,DEV=0
#
# VOICE_MIC_DEVICE=""
# VOICE_SPEAKER_DEVICE=""

# ── Wake word ─────────────────────────────────────────────────────────────────
# okay_nabu (default) | hey_jarvis | alexa
# VOICE_WAKE_WORD="okay_nabu"

# ── Speaker output routing ────────────────────────────────────────────────────
# By default the speaker uses the same audio card as the microphone.
# Set this if you want audio to come out of a different device — for example
# mic on the 2-Mic HAT but sound through HDMI or the Pi headphone jack.
#
# Options:
#   hdmi         — HDMI 1 (default HDMI on Pi 3, vc4hdmi0 on Pi 4/5)
#   hdmi2        — HDMI 2 (Pi 4 and Pi 5 only)
#   headphone    — 3.5mm headphone jack
#   usb_speaker  — first detected USB audio output
#   (any other value is used as a literal ALSA device name, e.g. plughw:2,0)
#
# Examples:
#   VOICE_SPEAKER_OUTPUT="hdmi"          # mic on HAT, audio through TV/display
#   VOICE_SPEAKER_OUTPUT="headphone"     # mic on USB, audio through 3.5mm jack
#   VOICE_SPEAKER_OUTPUT="plughw:2,0"    # explicit card number from aplay -l
#
# VOICE_SPEAKER_OUTPUT=""

# ── Satellite name and port ───────────────────────────────────────────────────
# Port 6053 is the ESPHome default — HA discovers it automatically via mDNS
# Only change if you have a port conflict
# VOICE_PORT=6053

# ── LED colors and brightness (2-Mic HAT only) ───────────────────────────────
# Applied when VOICE_HARDWARE=2mic_hat and VOICE_ENABLE_LEDS=true.
# The installer writes these to /etc/lva-leds.json which the LED service reads
# at startup. You can also edit /etc/lva-leds.json directly on the Pi and
# restart the service: sudo systemctl restart lva-2mic-leds
#
# Colors: "R G B" — each channel 0-255
# Brightness: integer 0-31 (APA102 hardware brightness, separate from color)
#
# LED_COLOR_DETECT="0 0 100"       # dim blue   — idle, waiting for wake word
# LED_COLOR_WAKE="0 255 0"         # green      — wake word heard
# LED_COLOR_LISTENING="0 0 200"    # blue       — streaming audio to HA
# LED_COLOR_PROCESSING="150 75 0"  # amber      — waiting for response
# LED_COLOR_SPEAKING="0 100 100"   # cyan       — playing TTS
# LED_COLOR_MUTED="200 0 0"        # red        — muted
# LED_COLOR_ERROR="200 0 0"        # red        — error
#
# LED_BRIGHTNESS_DETECT=4
# LED_BRIGHTNESS_WAKE=20
# LED_BRIGHTNESS_LISTENING=15
# LED_BRIGHTNESS_PROCESSING=10
# LED_BRIGHTNESS_SPEAKING=15
# LED_BRIGHTNESS_MUTED=1
# LED_BRIGHTNESS_ERROR=15

# ── Mute button (2-Mic HAT only) ─────────────────────────────────────────────
# The HAT's physical button is on GPIO 17, which the WM8960 codec also uses as
# its IRQ output. The button watcher filters out codec IRQ pulses (< 10ms) by
# only acting on presses held for at least BUTTON_PRESS_THRESHOLD seconds.
# Raise the threshold if you get phantom mute toggles during wake-word events;
# lower it if deliberate taps aren't being detected.
#
# VOICE_ENABLE_BUTTON=true
# BUTTON_GPIO=17
# BUTTON_PRESS_THRESHOLD=0.20
